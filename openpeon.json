{
  "cesp_version": "1.0",
  "name": "stronghold-wazir",
  "display_name": "The Wazir (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/wa_add_player_01.wav", "label": "Yes!" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/wa_willattack_01.wav", "label": "You better be right" },
        { "file": "sounds/wa_sent_01.wav", "label": "Do not waste them" },
        { "file": "sounds/wa_siege_01.wav", "label": "Desert will run red" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/wa_vict_01.wav", "label": "A mighty victory" },
        { "file": "sounds/wa_boast_01.wav", "label": "Another falls before me" },
        { "file": "sounds/wa_vict_04.wav", "label": "Fall like flies" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/wa_anger_01.wav", "label": "Warriors have failed me" },
        { "file": "sounds/wa_anger_02.wav", "label": "Wretched tin man" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/wa_help_01.wav", "label": "Swiftly to my rescue" },
        { "file": "sounds/wa_nervous_02.wav", "label": "We are weak" },
        { "file": "sounds/wa_req_01.wav", "label": "Send me these goods" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/wa_notsent_01.wav", "label": "No goods to spare" },
        { "file": "sounds/wa_nohelp_01.wav", "label": "Cannot help" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/wa_noattack_01.wav", "label": "CERTAIN DEATH, AND YOU KNOW IT" },
        { "file": "sounds/wa_kick_player_01.wav", "label": "Ah!" }
      ]
    }
  }
}
